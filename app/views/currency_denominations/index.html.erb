<div class="row">
  <div class="col-12">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><%= link_to "Currencies", currencies_path %></li>
        <li class="breadcrumb-item"><%= link_to @currency.name, currency_path(@currency) %></li>
        <li class="breadcrumb-item active">Denominations</li>
      </ol>
    </nav>
    
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1><%= @currency.name %> Denominations</h1>
        <p class="text-muted">All denominations for <%= @currency.name %></p>
      </div>
      <div>
        <%= link_to "Back to Currency", currency_path(@currency), class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-12 mb-4">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">Currency Information</h5>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-6">
            <p><strong>Currency:</strong> <%= @currency.name %></p>
            <p><strong>Code:</strong> <%= @currency.code %></p>
            <p><strong>Country:</strong> <%= @currency.country %></p>
          </div>
          <div class="col-md-6">
            <p><strong>Total Denominations:</strong> <%= @denominations.count %></p>
            <p><strong>Coins:</strong> <%= @denominations.coins.count %></p>
            <p><strong>Bills:</strong> <%= @denominations.bills.count %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-12">
    <h3>All Denominations</h3>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
      <% @denominations.each do |denomination| %>
        <div class="col">
          <%= render DenominationCardComponent.new(denomination: denomination) %>
        </div>
      <% end %>
    </div>
  </div>
</div>
