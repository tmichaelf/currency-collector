<div class="row">
  <div class="col-12">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><%= link_to "Currencies", currencies_path %></li>
        <li class="breadcrumb-item"><%= link_to @denomination.currency.name, currency_path(@denomination.currency) %></li>
        <li class="breadcrumb-item active"><%= @denomination.name %></li>
      </ol>
    </nav>
    
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1><%= @denomination.name %></h1>
        <p class="text-muted">$<%= @denomination.value %> - <%= @denomination.currency.name %></p>
      </div>
      <div>
        <%= link_to "Back to Currency", currency_path(@denomination.currency), class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-8">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">Denomination Information</h5>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-6">
            <p><strong>Name:</strong> <%= @denomination.name %></p>
            <p><strong>Value:</strong> $<%= @denomination.value %></p>
            <p><strong>Type:</strong> 
              <span class="badge bg-<%= @denomination.denomination_type == 'coin' ? 'warning' : 'success' %>">
                <%= @denomination.denomination_type.titleize %>
              </span>
            </p>
            <p><strong>Currency:</strong> <%= @denomination.currency.name %></p>
          </div>
          <div class="col-md-6">
            <p><strong>Introduced:</strong> <%= @denomination.year_introduced %></p>
            <% if @denomination.year_discontinued.present? %>
              <p><strong>Discontinued:</strong> <%= @denomination.year_discontinued %></p>
            <% else %>
              <p><strong>Status:</strong> <span class="badge bg-success">Current</span></p>
            <% end %>
            <p><strong>Active:</strong> 
              <span class="badge bg-<%= @denomination.is_active? ? 'success' : 'danger' %>">
                <%= @denomination.is_active? ? 'Yes' : 'No' %>
              </span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">Collection Statistics</h5>
      </div>
      <div class="card-body">
        <p><strong>Total in Collections:</strong> <%= @collections.count %></p>
        <p><strong>Total Quantity:</strong> <%= @collections.sum(:quantity) %></p>
        <p><strong>Total Value:</strong> $<%= number_with_precision(@collections.sum { |c| c.total_value }, precision: 2) %></p>
      </div>
    </div>
    
    <div class="card mt-3">
      <div class="card-header">
        <h5 class="mb-0">Actions</h5>
      </div>
      <div class="card-body">
        <div class="d-grid gap-2">
          <%= link_to "Add to Collection", new_currency_collection_path, class: "btn btn-primary" %>
          <%= link_to "View All Collections", currency_collections_path, class: "btn btn-outline-secondary" %>
        </div>
      </div>
    </div>
  </div>
</div>

<% if @collections.any? %>
  <div class="row mt-4">
    <div class="col-12">
      <h3>Collections Containing This Denomination</h3>
      <div class="table-responsive">
        <table class="table table-striped table-hover">
          <thead class="table-dark">
            <tr>
              <th>Collector</th>
              <th>Quantity</th>
              <th>Condition</th>
              <th>Total Value</th>
              <th>Acquired Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @collections.each do |collection| %>
              <tr>
                <td><%= collection.user.full_name %></td>
                <td><%= collection.quantity %></td>
                <td>
                  <span class="badge bg-<%= collection.condition == 'mint' ? 'success' : 'secondary' %>">
                    <%= collection.condition_display %>
                  </span>
                </td>
                <td>$<%= number_with_precision(collection.total_value, precision: 2) %></td>
                <td><%= collection.acquired_date.strftime("%B %d, %Y") %></td>
                <td>
                  <div class="btn-group btn-group-sm" role="group">
                    <%= link_to "View", collection, class: "btn btn-outline-primary" %>
                    <%= link_to "Edit", edit_currency_collection_path(collection), class: "btn btn-outline-secondary" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% else %>
  <div class="row mt-4">
    <div class="col-12">
      <div class="text-center py-4">
        <h4 class="text-muted">No collections yet</h4>
        <p class="text-muted">Be the first to add this denomination to your collection!</p>
        <%= link_to "Add to Collection", new_currency_collection_path, class: "btn btn-primary" %>
      </div>
    </div>
  </div>
<% end %>
