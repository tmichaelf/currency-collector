<div class="container mt-4">
  <div class="row">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Image Management</h1>
        <%= link_to "← Back to Admin", admin_path, class: "btn btn-outline-secondary" %>
      </div>
      
      <div class="row mb-4">
        <div class="col-md-3">
          <div class="card text-center">
            <div class="card-body">
              <h5 class="card-title"><%= @denominations_with_images.count %></h5>
              <p class="card-text">With Images</p>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card text-center">
            <div class="card-body">
              <h5 class="card-title"><%= @denominations_without_images.count %></h5>
              <p class="card-text">Without Images</p>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card text-center">
            <div class="card-body">
              <h5 class="card-title"><%= @denominations.select { |d| d.obverse_image.attached? }.count %></h5>
              <p class="card-text">With Obverse</p>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card text-center">
            <div class="card-body">
              <h5 class="card-title"><%= @denominations.select { |d| d.reverse_image.attached? }.count %></h5>
              <p class="card-text">With Reverse</p>
            </div>
          </div>
        </div>
      </div>
      
      <div class="row">
        <div class="col-md-6">
          <div class="card">
            <div class="card-header">
              <h5 class="mb-0">Denominations With Images</h5>
            </div>
            <div class="card-body">
              <% if @denominations_with_images.any? %>
                <div class="list-group">
                  <% @denominations_with_images.each do |denomination| %>
                    <div class="list-group-item">
                      <div class="d-flex justify-content-between align-items-start">
                        <div class="flex-grow-1">
                          <h6 class="mb-1"><%= denomination.name %></h6>
                          <p class="mb-1 text-muted"><%= denomination.currency.name %></p>
                          <div class="d-flex gap-2">
                            <% if denomination.obverse_image.attached? %>
                              <span class="badge bg-success">Obverse ✓</span>
                            <% else %>
                              <span class="badge bg-warning">No Obverse</span>
                            <% end %>
                            <% if denomination.reverse_image.attached? %>
                              <span class="badge bg-success">Reverse ✓</span>
                            <% else %>
                              <span class="badge bg-warning">No Reverse</span>
                            <% end %>
                          </div>
                        </div>
                        <div class="d-flex gap-1">
                          <%= link_to "View", currency_currency_denomination_path(denomination.currency, denomination), class: "btn btn-sm btn-outline-primary" %>
                          <%= link_to "Edit", edit_currency_currency_denomination_path(denomination.currency, denomination), class: "btn btn-sm btn-outline-secondary" %>
                        </div>
                      </div>
                      <div class="mt-2">
                        <% if denomination.obverse_image.attached? %>
                          <%= link_to "Delete Obverse", admin_delete_image_path(denomination, 'obverse'), 
                              method: :delete, 
                              data: { confirm: "Are you sure?" }, 
                              class: "btn btn-sm btn-outline-danger me-2" %>
                        <% end %>
                        <% if denomination.reverse_image.attached? %>
                          <%= link_to "Delete Reverse", admin_delete_image_path(denomination, 'reverse'), 
                              method: :delete, 
                              data: { confirm: "Are you sure?" }, 
                              class: "btn btn-sm btn-outline-danger" %>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <p class="text-muted mb-0">No denominations have images yet.</p>
              <% end %>
            </div>
          </div>
        </div>
        
        <div class="col-md-6">
          <div class="card">
            <div class="card-header">
              <h5 class="mb-0">Denominations Without Images</h5>
            </div>
            <div class="card-body">
              <% if @denominations_without_images.any? %>
                <div class="list-group">
                  <% @denominations_without_images.each do |denomination| %>
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                      <div>
                        <h6 class="mb-1"><%= denomination.name %></h6>
                        <p class="mb-0 text-muted"><%= denomination.currency.name %></p>
                      </div>
                      <div class="d-flex gap-1">
                        <%= link_to "Add Images", edit_currency_currency_denomination_path(denomination.currency, denomination), class: "btn btn-sm btn-primary" %>
                        <%= link_to "Bulk Upload", admin_bulk_image_upload_path, class: "btn btn-sm btn-outline-secondary" %>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <p class="text-muted mb-0">All denominations have images!</p>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div> 