<div class="row">
  <div class="col-12">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><%= link_to "Collections", currency_collections_path %></li>
        <li class="breadcrumb-item active">Collection Details</li>
      </ol>
    </nav>
    
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1>Collection Details</h1>
      <div>
        <%= link_to "Edit", edit_currency_collection_path(@collection), class: "btn btn-outline-primary" %>
        <%= link_to "Back to Collections", currency_collections_path, class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-8">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">Item Information</h5>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-6">
            <p><strong>Denomination:</strong> <%= @collection.currency_denomination.name %></p>
            <p><strong>Currency:</strong> <%= @collection.currency_denomination.currency.name %></p>
            <p><strong>Value:</strong> $<%= @collection.currency_denomination.value %></p>
            <p><strong>Type:</strong> 
              <span class="badge bg-<%= @collection.currency_denomination.denomination_type == 'coin' ? 'warning' : 'success' %>">
                <%= @collection.currency_denomination.denomination_type.titleize %>
              </span>
            </p>
          </div>
          <div class="col-md-6">
            <p><strong>Quantity:</strong> <%= @collection.quantity %></p>
            <p><strong>Total Value:</strong> $<%= number_with_precision(@collection.total_value, precision: 2) %></p>
            <p><strong>Condition:</strong> 
              <span class="badge bg-<%= @collection.condition == 'mint' ? 'success' : 'secondary' %>">
                <%= @collection.condition_display %>
              </span>
            </p>
            <p><strong>Acquired:</strong> <%= @collection.acquired_date.strftime("%B %d, %Y") %></p>
          </div>
        </div>
        
        <% if @collection.notes.present? %>
          <div class="mt-3">
            <h6>Notes:</h6>
            <p class="text-muted"><%= @collection.notes %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
  
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">Denomination History</h5>
      </div>
      <div class="card-body">
        <p><strong>Introduced:</strong> <%= @collection.currency_denomination.year_introduced %></p>
        <% if @collection.currency_denomination.year_discontinued.present? %>
          <p><strong>Discontinued:</strong> <%= @collection.currency_denomination.year_discontinued %></p>
        <% else %>
          <p><strong>Status:</strong> <span class="badge bg-success">Current</span></p>
        <% end %>
      </div>
    </div>
    
    <div class="card mt-3">
      <div class="card-header">
        <h5 class="mb-0">Actions</h5>
      </div>
      <div class="card-body">
        <div class="d-grid gap-2">
          <%= link_to "Edit Collection", edit_currency_collection_path(@collection), class: "btn btn-primary" %>
          <%= link_to "Delete Collection", @collection, method: :delete, data: { confirm: "Are you sure you want to delete this collection item?" }, class: "btn btn-danger" %>
        </div>
      </div>
    </div>
  </div>
</div>
