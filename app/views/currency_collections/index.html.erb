<div class="row">
  <div class="col-12">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1>Currency Collections</h1>
      <div>
        <%= link_to "Add New Collection", new_currency_collection_path, class: "btn btn-primary" %>
        <%= link_to "View Currencies", currencies_path, class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>
</div>

<% if @collections.any? %>
  <div class="row">
    <div class="col-12">
      <div class="table-responsive">
        <table class="table table-striped table-hover">
          <thead class="table-dark">
            <tr>
              <th>Denomination</th>
              <th>Quantity</th>
              <th>Condition</th>
              <th>Total Value</th>
              <th>Acquired Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @collections.each do |collection| %>
              <tr>
                <td>
                  <strong><%= collection.currency_denomination.name %></strong>
                  <br><small class="text-muted"><%= collection.currency_denomination.currency.name %></small>
                </td>
                <td><%= collection.quantity %></td>
                <td>
                  <span class="badge bg-<%= collection.condition == 'mint' ? 'success' : 'secondary' %>">
                    <%= collection.condition_display %>
                  </span>
                </td>
                <td>$<%= number_with_precision(collection.total_value, precision: 2) %></td>
                <td><%= collection.acquired_date.strftime("%B %d, %Y") %></td>
                <td>
                  <div class="btn-group btn-group-sm" role="group">
                    <%= link_to "View", collection, class: "btn btn-outline-primary" %>
                    <%= link_to "Edit", edit_currency_collection_path(collection), class: "btn btn-outline-secondary" %>
                    <%= link_to "Delete", collection, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-outline-danger" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% else %>
  <div class="row">
    <div class="col-12">
      <div class="text-center py-5">
        <h3 class="text-muted">No collections yet</h3>
        <p class="text-muted">Start building your currency collection by adding your first item.</p>
        <%= link_to "Add Your First Collection", new_currency_collection_path, class: "btn btn-primary btn-lg" %>
      </div>
    </div>
  </div>
<% end %>
