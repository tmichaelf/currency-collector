<div class="row">
  <div class="col-12">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><%= link_to "Currencies", currencies_path %></li>
        <li class="breadcrumb-item active"><%= @currency.name %></li>
      </ol>
    </nav>
    
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1><%= @currency.name %></h1>
        <p class="text-muted"><%= @currency.description %></p>
      </div>
      <div>
        <%= link_to "Back to Currencies", currencies_path, class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-12 mb-4">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">Currency Information</h5>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-6">
            <p><strong>Code:</strong> <%= @currency.code %></p>
            <p><strong>Country:</strong> <%= @currency.country %></p>
          </div>
          <div class="col-md-6">
            <p><strong>Total Denominations:</strong> <%= @denominations.count %></p>
            <p><strong>Status:</strong> 
              <span class="badge bg-<%= @currency.is_active? ? 'success' : 'danger' %>">
                <%= @currency.is_active? ? 'Active' : 'Inactive' %>
              </span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row mb-3">
  <div class="col-12">
    <h3 class="h5 text-secondary">Coins</h3>
  </div>
</div>
<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-5">
  <% @coin_denominations.each do |denomination| %>
    <div class="col">
      <%= render DenominationCardComponent.new(denomination: denomination) %>
    </div>
  <% end %>
</div>

<div class="row mb-3">
  <div class="col-12">
    <h3 class="h5 text-secondary">Paper</h3>
  </div>
</div>
<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
  <% @bill_denominations.each do |denomination| %>
    <div class="col">
      <%= render DenominationCardComponent.new(denomination: denomination) %>
    </div>
  <% end %>
</div>
