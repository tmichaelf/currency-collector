<div class="card h-100 shadow-sm">
  <div class="card-img-top" style="height: 200px; overflow: hidden; background: #f8f9fa;">
    <%= denomination_image_tag(denomination, :obverse, class: "w-100 h-100", style: "object-fit: contain;") %>
  </div>
  
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h5 class="card-title"><%= denomination.name %></h5>
        <h6 class="card-subtitle mb-2 text-muted">$<%= denomination.value %></h6>
      </div>
      <span class="badge bg-<%= denomination.denomination_type == 'coin' ? 'warning' : 'success' %>">
        <%= denomination.denomination_type.titleize %>
      </span>
    </div>
    <p class="card-text small">
      <strong>Introduced:</strong> <%= denomination.year_introduced %>
      <% if denomination.year_discontinued.present? %>
        <br><strong>Discontinued:</strong> <%= denomination.year_discontinued %>
      <% end %>
    </p>
  </div>
  <div class="card-footer bg-transparent">
    <div class="d-flex justify-content-between align-items-center">
      <span class="badge bg-info"><%= denomination.currency_collections.count %> in collections</span>
      <%= link_to "View Details", currency_currency_denomination_path(denomination.currency, denomination), class: "btn btn-outline-primary btn-sm" %>
    </div>
  </div>
</div> 